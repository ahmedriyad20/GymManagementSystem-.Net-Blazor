@page "/expenses/new"
@attribute [Authorize]
@inject ApiClient ApiClient
@inject NavigationManager Navigation

<div class="expense-create-page mx-auto" style="max-width: 900px;">
    <div class="mb-4 d-flex align-items-center gap-2">
        <button type="button" class="btn btn-light" @onclick='() => Navigation.NavigateTo("/expenses")'>
            <i class="bi bi-arrow-right"></i>
        </button>
        <div>
            <h1 class="display-6 fw-bold mb-1">تسجيل مصروف جديد</h1>
            <p class="text-secondary mb-0">أدخل تفاصيل المصروف لإضافته إلى السجلات المالية.</p>
        </div>
    </div>

    <EditForm Model="command" OnValidSubmit="SaveAsync">
        <DataAnnotationsValidator />

        <div class="card border-0 shadow-sm trainees-table-card">
            <div class="card-body p-4">
                <div class="mb-3">
                    <label class="form-label">وصف المصروف</label>
                    <InputText class="form-control" @bind-Value="command.Description" />
                </div>

                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <label class="form-label">المبلغ المدفوع</label>
                        <InputNumber class="form-control" @bind-Value="command.Amount" />
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label">تاريخ الدفع</label>
                        <InputDate class="form-control" @bind-Value="command.ExpenseDate" />
                    </div>
                </div>

                <div class="row g-3 mt-1">
                    <div class="col-12 col-md-6">
                        <label class="form-label">الفئة</label>
                        <InputText class="form-control" @bind-Value="command.Category" placeholder="مثال: صيانة، فواتير، مستلزمات" />
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label">الشخص المسؤول (الدافع)</label>
                        <InputText class="form-control" @bind-Value="command.PaidBy" placeholder="مثال: أحمد مدير الصالة" />
                    </div>
                </div>

                <div class="mt-3">
                    <label class="form-label">ملاحظات إضافية</label>
                    <InputTextArea class="form-control" @bind-Value="command.Notes" rows="4" />
                </div>
            </div>
            <div class="card-footer bg-white d-flex justify-content-end gap-2">
                <button type="button" class="btn btn-outline-secondary" @onclick='() => Navigation.NavigateTo("/expenses")' disabled="@saving">إلغاء</button>
                <button type="submit" class="btn btn-primary" disabled="@saving">
                    @(saving ? "جاري الحفظ..." : "حفظ المصروف")
                </button>
            </div>
        </div>
    </EditForm>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <div class="alert mt-3 @(isError ? "alert-danger" : "alert-success")">@message</div>
    }
</div>

@code {
    private bool saving;
    private bool isError;
    private string? message;

    private CreateExpenseCommand command = new()
    {
        ExpenseDate = DateTime.Today
    };

    private async Task SaveAsync()
    {
        isError = false;
        message = null;

        if (string.IsNullOrWhiteSpace(command.Description) || string.IsNullOrWhiteSpace(command.Category) || command.Amount <= 0)
        {
            isError = true;
            message = "يرجى إدخال الوصف والفئة ومبلغ صحيح قبل الحفظ.";
            return;
        }

        saving = true;
        try
        {
            await ApiClient.CreateExpenseAsync(command);
            message = "تم تسجيل المصروف بنجاح.";
            Navigation.NavigateTo($"/expenses?refresh={DateTime.UtcNow.Ticks}", true);
        }
        catch (Exception ex)
        {
            isError = true;
            message = ex.Message;
        }
        finally
        {
            saving = false;
        }
    }
}
