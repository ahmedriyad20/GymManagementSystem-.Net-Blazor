@page "/login"
@attribute [AllowAnonymous]
@layout EmptyLayout
@inject ApiClient ApiClient
@inject JwtAuthenticationStateProvider AuthProvider
@inject NavigationManager Navigation

<PageTitle>تسجيل الدخول | Lion Gym</PageTitle>

<div class="login-page d-flex align-items-center justify-content-center min-vh-100 p-3">
    <div class="login-card card border-0 shadow-lg overflow-hidden">
        <div class="card-body p-0">
            <div class="login-header text-center px-4 px-md-5 py-5">
                <div class="icon-box mx-auto mb-3 d-flex align-items-center justify-content-center">
                    <i class="bi bi-shield-lock fs-3 text-primary"></i>
                </div>
                <h1 class="h2 fw-bold mb-2">Lion Gym</h1>
                <p class="text-secondary mb-0">بوابة إدارة الجيم</p>
            </div>

            <div class="border-top px-4 px-md-5 py-4">
                <EditForm Model="loginModel" OnValidSubmit="SubmitAsync">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="text-danger small mb-3" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">سياق الوصول</label>
                        <select class="form-select" @bind="accessScope">
                            <option value="full">وصول كامل للمرفق</option>
                            <option value="female">حساب قسم السيدات</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">اسم المستخدم</label>
                        <InputText @bind-Value="loginModel.UserName" class="form-control form-control-lg" placeholder="أدخل اسم المستخدم" />
                    </div>

                    <div class="mb-2">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <label class="form-label fw-semibold mb-0">كلمة المرور</label>
                            <a href="#" class="small text-decoration-none">هل نسيت كلمة المرور؟</a>
                        </div>
                        <InputText @bind-Value="loginModel.Password" type="password" class="form-control form-control-lg" placeholder="••••••••" />
                    </div>

                    <button class="btn btn-primary btn-lg w-100 mt-4" type="submit" disabled="@isSubmitting">
                        <i class="bi bi-box-arrow-in-left ms-2"></i>
                        @((isSubmitting ? "جاري تسجيل الدخول..." : "تسجيل دخول آمن"))
                    </button>
                </EditForm>

                @if (!string.IsNullOrWhiteSpace(errorMessage))
                {
                    <div class="alert alert-danger mt-3 mb-0">@errorMessage</div>
                }

                <p class="text-center text-secondary mt-4 mb-0">
                    هل تحتاج إلى وصول للنظام؟
                    <a href="#" class="text-decoration-none">اتصل بمسؤول النظام</a>
                </p>
            </div>
        </div>
    </div>
</div>

@code {
    private readonly LoginCommand loginModel = new();
    private string accessScope = "full";
    private string? errorMessage;
    private bool isSubmitting;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthProvider.GetAuthenticationStateAsync();
        if (state.User.Identity?.IsAuthenticated == true)
        {
            Navigation.NavigateTo("/trainees", true);
        }
    }

    private async Task SubmitAsync()
    {
        isSubmitting = true;
        errorMessage = null;

        try
        {
            var result = await ApiClient.LoginAsync(loginModel);
            if (result?.IsAuthenticated == true && !string.IsNullOrWhiteSpace(result.Token))
            {
                await AuthProvider.MarkUserAsAuthenticatedAsync(result.Token, result.RefreshToken);
                Navigation.NavigateTo("/trainees", true);
                return;
            }

            errorMessage = result?.Message ?? string.Join(", ", result?.Errors ?? []);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
